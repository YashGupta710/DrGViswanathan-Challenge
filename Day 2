876. Middle of the Linked List
 code for this question in c++
class Solution {
public:
    ListNode* middleNode(ListNode* head) {
        ListNode* slow = head;
        ListNode* fast = head;
        while(fast != NULL && fast->next != NULL){
            slow= slow->next;
            fast = fast->next->next;
        }
        return slow;


    }
};

258. Add Digits
code for this question in c++
class Solution {
public:
    int addDigits(int num) {
        if(num==0) return 0;
        if(num%9==0) return 0;
        return num%9;
    }
};
